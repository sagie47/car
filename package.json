{
  "name": "lotpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Marketplace-first inventory reliability engine for dealers",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push:test": "node scripts/prisma-push-test.mjs",
    "test": "node --test --test-concurrency=1 test/unit/*.test.js",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:all": "npm test && npm run test:integration"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.6.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^7.7.0"
  }
}
