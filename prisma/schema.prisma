generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dealer {
  id        String             @id
  name      String
  createdAt DateTime
  rooftops  Rooftop[]
  syncRuns  InventorySyncRun[]
  vehicles  Vehicle[]
  memberships DealerMembership[]
  invitations DealerInvitation[]
}

model UserProfile {
  id             String             @id
  email          String             @unique
  displayName    String?
  phone          String?
  createdAt      DateTime
  updatedAt      DateTime
  memberships    DealerMembership[]
  rooftopAccess  RooftopAccess[]
  recipients     NotificationRecipient[]
}

model DealerMembership {
  id        String      @id
  dealerId  String
  userId    String
  role      String
  createdAt DateTime
  dealer    Dealer      @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealerId, userId])
  @@index([userId])
}

model RooftopAccess {
  id        String      @id
  rooftopId String
  userId    String
  createdAt DateTime
  rooftop   Rooftop     @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rooftopId, userId])
  @@index([userId])
}

model DealerInvitation {
  id          String   @id
  dealerId    String
  email       String
  role        String
  rooftopIds  Json
  status      String
  invitedById String?
  createdAt   DateTime
  acceptedAt  DateTime?
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId])
  @@index([email])
}

model Rooftop {
  id             String             @id
  dealerId       String
  name           String
  location       String?
  phone          String?
  logoUrl        String?
  disclaimerText String?
  assignmentMode String
  rules          Json
  createdAt      DateTime
  dealer         Dealer             @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  inventorySources InventorySource[]
  syncRuns       InventorySyncRun[]
  vehicles       Vehicle[]
  listings       Listing[]
  leads          Lead[]
  accessGrants   RooftopAccess[]
  recipients     NotificationRecipient[]

  @@index([dealerId])
}

model InventorySource {
  id             String             @id
  rooftopId      String
  name           String
  type           String
  format         String
  sourceUrl      String?
  sourceConfig   Json
  isActive       Boolean
  lastSyncedAt   DateTime?
  lastSyncStatus String?
  createdAt      DateTime
  updatedAt      DateTime
  rooftop        Rooftop            @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  syncRuns       InventorySyncRun[]

  @@index([rooftopId])
}

model InventorySyncRun {
  id            String   @id
  dealerId      String
  rooftopId     String
  inventorySourceId String?
  sourceType    String
  sourceName    String?
  status        String   @default("completed")
  trigger       String   @default("manual")
  startedAt     DateTime
  completedAt   DateTime?
  rowsReceived  Int
  rowsImported  Int
  rowsSkipped   Int
  duplicateVins Json
  errors        Json
  dealer        Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  inventorySource InventorySource? @relation(fields: [inventorySourceId], references: [id], onDelete: SetNull)
  rooftop       Rooftop  @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  snapshots     VehicleSnapshot[]

  @@index([inventorySourceId])
  @@index([rooftopId])
  @@index([dealerId])
}

model Vehicle {
  id                    String            @id
  dealerId              String
  rooftopId             String
  vin                   String?
  stockNumber           String?
  year                  Int?
  make                  String?
  model                 String?
  trim                  String?
  condition             String?
  mileage               Int?
  price                 Int?
  bodyStyle             String?
  exteriorColor         String?
  interiorColor         String?
  photoUrls             Json
  status                String?
  vdpUrl                String?
  salespersonAssignment String?
  carfaxUrl             String?
  optionsList           Json
  drivetrain            String?
  transmission          String?
  fuelType              String?
  engine                String?
  daysInInventory       Int?
  featured              Boolean
  priceHistory          Json
  rawSource             Json
  naturalKey            String            @unique
  sourceFingerprint     String
  syncIssues            Json
  isStale               Boolean
  eligibility           Json
  createdAt             DateTime
  updatedAt             DateTime
  dealer                Dealer            @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  rooftop               Rooftop           @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  snapshots             VehicleSnapshot[]
  listing               Listing?
  leads                 Lead[]

  @@index([rooftopId])
  @@index([dealerId])
}

model VehicleSnapshot {
  id          String           @id
  vehicleId   String
  syncRunId   String
  capturedAt  DateTime
  fingerprint String
  rawSource   Json
  vehicle     Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  syncRun     InventorySyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([vehicleId, capturedAt])
  @@index([syncRunId])
}

model Listing {
  id        String         @id
  vehicleId String         @unique
  rooftopId String
  state     String
  draft     Json
  createdAt DateTime
  updatedAt DateTime
  vehicle   Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  rooftop   Rooftop        @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  events    ListingEvent[]

  @@index([rooftopId])
}

model ListingEvent {
  id        String   @id
  listingId String
  fromState String?
  toState   String
  actor     String
  reason    String?
  metadata  Json
  eventType String   @default("state_transition")
  createdAt DateTime
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

model Lead {
  id                String      @id
  vehicleId         String
  rooftopId         String
  sourceChannel     String
  sourceSubchannel  String?
  assignedRepId     String?
  createdAt         DateTime
  firstResponseAt   DateTime?
  status            String
  disposition       String?
  appointmentSet    Boolean
  sold              Boolean
  attributedValue   Int?
  suggestedResponse String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  sourceMessage     String?
  externalId        String?     @unique
  vehicle           Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  rooftop           Rooftop     @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  events            LeadEvent[]
  inboundEvents     InboundEvent[]
  deliveries        NotificationDelivery[]

  @@index([rooftopId])
  @@index([status])
}

model LeadEvent {
  id        String   @id
  leadId    String
  type      String
  actor     String
  metadata  Json
  createdAt DateTime
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model NotificationRecipient {
  id        String      @id
  rooftopId String
  userId    String?
  channel   String
  destination String
  isActive  Boolean
  createdAt DateTime
  updatedAt DateTime
  rooftop   Rooftop     @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  user      UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveries NotificationDelivery[]

  @@unique([rooftopId, channel, destination])
  @@index([rooftopId])
}

model InboundEvent {
  id          String   @id
  provider    String
  externalId  String   @unique
  rooftopId   String
  leadId      String?
  payload     Json
  receivedAt  DateTime
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([rooftopId, receivedAt])
}

model NotificationDelivery {
  id          String                @id
  leadId      String
  recipientId String
  channel     String
  status      String
  attempts    Int
  providerId  String?
  lastError   String?
  createdAt   DateTime
  updatedAt   DateTime
  lead        Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  recipient   NotificationRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
}
